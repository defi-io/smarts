<!DOCTYPE html>
<html>
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Smarts">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <% if @canonical_slug %>
      <link rel="canonical" href="<%= request.protocol %><%= request.host_with_port %>/<%= @canonical_slug %>">
    <% end %>

    <%= render_social_meta %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="overflow-x-hidden">
    <%# Match main's mobile padding so the nav logo left-aligns with
        below-the-fold content (H1, address, cards). %>
    <nav class="border-b border-gray-200 px-3 sm:px-5 py-3">
      <div class="container mx-auto flex items-center justify-between">
        <%# Brand wordmark: "smarts" bold, ".md" muted — signals "the brand is
            Smarts, the domain just happens to be .md", without ALL-CAPS or
            capitalized-brand awkwardness. %>
        <a href="/" class="text-xl font-bold text-gray-900 hover:text-gray-700">
          smarts<span class="text-gray-500 font-normal">.md</span>
        </a>
      </div>
    </nav>
    <%# Block, not flex — flex items get min-width:auto which lets unbreakable
        content (long hex addresses, <pre> source blocks) expand past the
        viewport on mobile. A plain block container respects viewport width.
        Mobile side padding kept tight (12px) to maximize content area on
        narrow screens; widens at sm+ for breathing room on desktop. %>
    <main class="container mx-auto px-3 sm:px-5">
      <%= yield %>
    </main>
    <footer class="container mx-auto px-3 sm:px-5 py-8 mt-12 border-t border-gray-200">
      <p class="text-xs text-gray-600"><%= Time.now.year %> · Built by <a href="https://chain.dev" class="text-gray-500 hover:text-gray-400 underline">chain.dev</a></p>
    </footer>
    <!-- 100% privacy-first analytics -->
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </body>
</html>

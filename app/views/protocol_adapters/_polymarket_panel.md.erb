<% data = adapter.panel_data %>
## Polymarket (<%= data[:role_label] %>)

<% if data[:error] %>
_Could not load Polymarket market summary: <%= data[:error] %>_
<% elsif data[:top_markets].present? %>
<%= data[:source_label] || "Top active markets from Gamma" %>:

<% data[:top_markets].each do |market| %>
- **<%= market.question.presence || market.slug %>**<% if market.volume_num %> — volume $<%= number_with_delimiter(market.volume_num.round(0).to_i) %><% end %>
  - slug: `<%= market.slug %>`
  - condition_id: `<%= market.condition_id %>`
  - tags: <%= Array(market.tags).first(3).join(", ") %>
  - outcomes: <%= market.tokens.map { |token| "#{token.outcome}=#{token.price&.to_s("F") || "?"}" }.join(", ") %>
<% end %>
<% else %>
No active Polymarket markets returned by Gamma.
<% end %>

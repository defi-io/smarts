<% data = adapter.panel_data %>
## <%= adapter.display_name %>

<%= adapter.exchange_description %>

<% if data[:error] %>
_Could not read on-chain activity: <%= data[:error] %>_
<% else %>
**Last ~3h on-chain** (through block <%= data[:window_block_to] %>):

- Fills: <%= number_with_delimiter(data[:fills_count] || 0) %>
- Volume: $<%= number_with_delimiter((data[:volume_usdc] || 0).round(0).to_i) %>
- Unique takers: <%= number_with_delimiter(data[:unique_takers] || 0) %>
- Markets touched: <%= number_with_delimiter(data[:unique_markets] || 0) %>

<% if data[:top_markets].present? %>
### Most active markets

<% data[:top_markets].each do |market| %>
- **<%= market.market_label %>** — <%= market.fills_count %> fills, $<%= number_with_delimiter(market.volume_usdc.round(0).to_i) %><% if market.slug %> (`<%= market.slug %>`)<% end %>
<% end %>
<% end %>

<% if data[:latest_fills].present? %>
### Latest fills

<% data[:latest_fills].each do |fill| %>
- <%= fill.side %> @ <%= fill.price.to_s("F") %> · $<%= number_with_delimiter(fill.usdc_amount.round(2)) %> · <%= fill.market_label %>
<% end %>
<% end %>
<% end %>


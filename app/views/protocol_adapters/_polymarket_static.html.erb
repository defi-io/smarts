<% data = adapter.panel_data %>

<div class="card bg-base-100 border border-base-300 mb-6">
  <div class="card-body">
    <div class="text-xs opacity-60 font-mono mb-1">Polymarket</div>
    <h2 class="text-2xl font-bold"><%= adapter.display_name %></h2>
    <p class="text-sm opacity-70 mt-1"><%= adapter.architecture_summary %></p>
    <% if data[:static] %>
      <p class="text-xs opacity-50 mt-4">
        This contract is documented as part of the Polymarket settlement architecture; live activity is shown on the exchange, CTF, UMA, and neg-risk adapter pages.
      </p>
    <% end %>
  </div>
</div>

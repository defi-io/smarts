<% data = adapter.panel_data %>

<%= polymarket_panel_frame do %>
<div class="card bg-base-100 border border-base-300 mb-6">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <div class="text-xs opacity-60 font-mono mb-1">Polymarket</div>
        <h2 class="text-2xl font-bold"><%= adapter.display_name %></h2>
        <p class="text-sm opacity-70 mt-1">Outcome-token ledger (Gnosis ConditionalTokens) · ERC-1155 · Polygon</p>
      </div>
    </div>

    <% if data[:errors].present? %>
      <div class="alert alert-warning mt-4 text-sm">
        Some on-chain reads failed:
        <ul class="ml-4 list-disc">
          <% data[:errors].each do |event_name, message| %>
            <li><%= event_name %>: <%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if data[:resolutions].present? %>
      <div class="divider mt-4 mb-2"></div>
      <h3 class="text-sm font-semibold opacity-80 mb-2">Recently resolved conditions</h3>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr><th></th><th>Market</th><th>Payouts</th></tr>
          </thead>
          <tbody>
            <% data[:resolutions].each do |res| %>
              <tr>
                <td class="text-xs opacity-60 whitespace-nowrap"><%= time_ago_short(parse_iso(res.timestamp)) %> ago</td>
                <td>
                  <div class="text-sm max-w-md"><%= res.market_label %></div>
                  <% if res.slug.present? %>
                    <div class="text-xs opacity-60 font-mono"><%= res.slug %></div>
                  <% end %>
                </td>
                <td class="font-mono text-xs">[<%= res.payouts.join(", ") %>]</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if data[:preparations].present? %>
      <div class="divider mt-4 mb-2"></div>
      <h3 class="text-sm font-semibold opacity-80 mb-2">Recently prepared conditions (new markets)</h3>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr><th></th><th>Market</th><th>Outcomes</th></tr>
          </thead>
          <tbody>
            <% data[:preparations].each do |prep| %>
              <tr>
                <td class="text-xs opacity-60 whitespace-nowrap"><%= time_ago_short(parse_iso(prep.timestamp)) %> ago</td>
                <td>
                  <div class="text-sm max-w-md"><%= prep.market_label %></div>
                  <% if prep.slug.present? %>
                    <div class="text-xs opacity-60 font-mono"><%= prep.slug %></div>
                  <% end %>
                </td>
                <td class="font-mono text-xs"><%= prep.outcome_slot_count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if data[:redemptions].present? %>
      <div class="divider mt-4 mb-2"></div>
      <h3 class="text-sm font-semibold opacity-80 mb-2">Recent redemptions</h3>
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead>
            <tr><th></th><th>Redeemer</th><th class="text-right">Payout</th></tr>
          </thead>
          <tbody>
            <% data[:redemptions].each do |redeem| %>
              <tr>
                <td class="text-xs opacity-60 whitespace-nowrap"><%= time_ago_short(parse_iso(redeem.timestamp)) %> ago</td>
                <td class="font-mono text-xs"><%= redeem.redeemer&.then { |a| "#{a[0..7]}…#{a[-4..]}" } %></td>
                <td class="text-right font-mono text-sm">
                  <% if redeem.payout %>
                    $<%= number_with_delimiter(redeem.payout.round(2)) %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% if data[:resolutions].blank? && data[:preparations].blank? && data[:redemptions].blank? %>
      <p class="text-sm opacity-70 mt-6">No CTF activity in the last ~3h.</p>
    <% end %>

    <div class="text-xs opacity-50 mt-6">
      Ask your AI to audit a market's on-chain payout vector and whether its outcome tokens are redeemable.
    </div>
  </div>
</div>
<% end %>

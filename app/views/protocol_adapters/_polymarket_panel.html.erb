<% data = adapter.panel_data %>

<div class="card bg-base-100 border border-base-300 mb-6">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <div class="text-xs opacity-60 font-mono mb-1"><%= adapter.protocol_name %></div>
        <h2 class="text-2xl font-bold"><%= adapter.display_name %></h2>
        <p class="text-sm opacity-70 mt-1"><%= data[:role_label] %></p>
        <% if data[:source_label].present? %>
          <p class="text-xs opacity-60 mt-1"><%= data[:source_label] %></p>
        <% end %>
      </div>
      <% if (tag = panel_freshness_tag(data)) %>
        <div class="self-start"><%= tag %></div>
      <% end %>
    </div>

    <% if data[:error] %>
      <div class="alert alert-warning mt-4">
        Could not load Polymarket market summary: <%= data[:error] %>
      </div>
    <% elsif data[:top_markets].present? %>
      <div class="overflow-x-auto mt-6">
        <table class="table table-sm">
          <thead>
            <tr>
              <th>Market</th>
              <th>Outcomes</th>
              <th class="text-right">Volume</th>
            </tr>
          </thead>
          <tbody>
            <% data[:top_markets].each do |market| %>
              <tr>
                <td>
                  <div class="font-medium max-w-xl"><%= market.question.presence || market.slug %></div>
                  <% if market.slug.present? %>
                    <div class="text-xs opacity-60 font-mono"><%= market.slug %></div>
                  <% end %>
                  <% if market.tags.present? %>
                    <div class="text-xs opacity-50 mt-1"><%= market.tags.first(3).join(" · ") %></div>
                  <% end %>
                </td>
                <td class="font-mono text-xs">
                  <%= market.tokens.map { |token| "#{token.outcome}: #{token.price&.to_s("F") || "?"}" }.join(" / ") %>
                </td>
                <td class="text-right font-mono">
                  <% if market.volume_num %>
                    $<%= number_with_delimiter(market.volume_num.round(0).to_i) %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm opacity-70 mt-4">No active Polymarket markets returned by Gamma.</p>
    <% end %>
  </div>
</div>

<%= turbo_stream_from @contract %>

<%
  contract_name = contract_display_name
  seo_title = "#{contract_name} on #{@chain.name} — live on-chain contract docs"
  seo_desc  =
    if @classification&.display_name.present?
      "Live on-chain docs for #{contract_name} (#{@classification.display_name}) on #{@chain.name}. Supply, admin controls, live state, and source — read straight from the chain."
    else
      "Live on-chain docs for #{contract_name} at #{@contract.display_address} on #{@chain.name}. View functions, admin controls, source code — current from the chain."
    end
  seo_canonical =
    @canonical_slug ? "#{SeoHelper::SITE_URL}/#{@canonical_slug}" : "#{SeoHelper::SITE_URL}/#{@chain.slug}/#{@contract.address}"
  seo_meta title: seo_title, description: seo_desc, canonical: seo_canonical
%>

<% content_for :head do %>
  <%= contract_json_ld(contract: @contract, chain: @chain, classification: @classification, display_name: contract_name) %>
  <%= breadcrumb_json_ld([
    { name: "Smarts", url: "#{SeoHelper::SITE_URL}/" },
    { name: "#{contract_name} on #{@chain.name}", url: seo_canonical }
  ]) %>
<% end %>

<%# Inner px-0 — outer <main> in the layout already supplies horizontal
    padding. Doubling was wasting ~72px of mobile width. %>
<div class="max-w-5xl mx-auto py-4 sm:py-8">
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2 flex-wrap">
      <h1 class="text-3xl font-bold"><%= contract_name %></h1>
      <span class="badge badge-primary"><%= @chain.name %></span>
      <% if @classification %>
        <span class="badge badge-outline" title="<%= @classification.description %>">
          <%= @classification.display_name %>
        </span>
      <% end %>
    </div>
    <p class="font-mono text-sm opacity-70 break-all"><%= @contract.address %></p>
    <% if @contract.implementation_address.present? %>
      <p class="text-sm opacity-70 mt-1 break-all">
        <span class="badge badge-ghost badge-sm">Proxy</span>
        <span class="opacity-60">implementation:</span>
        <span class="font-mono"><%= @contract.implementation_address %></span>
      </p>
    <% end %>
    <% if @contract.compiler_version.present? %>
      <p class="text-sm opacity-50 mt-1">Solidity <%= @contract.compiler_version %></p>
    <% end %>
    <% if @classification&.description.present? %>
      <p class="text-sm opacity-70 mt-2 italic"><%= @classification.description %></p>
    <% end %>
  </div>

  <%= render "contracts/mcp_info" %>

  <% if @protocol_adapter %>
    <%= render @protocol_adapter.template_partial, adapter: @protocol_adapter %>
  <% end %>

  <%= render "contracts/admin_risk" %>

  <% activity_selected = params[:event_name].present? %>
  <% governance_selected = params[:gov_category].present? %>
  <% docs_selected = !activity_selected && !governance_selected %>
  <%# data-turbo-permanent on each tab radio so user's selection survives the
      background-job-triggered Turbo morph refresh. Server-rendered `checked`
      still wins on initial load (when there's no client state to preserve). %>
  <div role="tablist" class="tabs tabs-lift tabs-lg" data-controller="contract-tabs">
    <input id="contract_tab_docs" data-turbo-permanent type="radio" name="contract_view" role="tab" class="tab" aria-label="Docs" <%= "checked" if docs_selected %> />
    <div role="tabpanel" class="tab-content bg-base-100 border-base-300 p-6">
      <%= render "contracts/docs" %>
    </div>

    <input id="contract_tab_activity" data-turbo-permanent type="radio" name="contract_view" role="tab" class="tab" aria-label="Live Activity" data-contract-tabs-target="activity" <%= "checked" if activity_selected %> />
    <div role="tabpanel" class="tab-content bg-base-100 border-base-300 p-6">
      <%= render "contracts/activity" %>
    </div>

    <input id="contract_tab_governance" data-turbo-permanent type="radio" name="contract_view" role="tab" class="tab" aria-label="Governance" data-contract-tabs-target="governance" <%= "checked" if governance_selected %> />
    <div role="tabpanel" class="tab-content bg-base-100 border-base-300 p-6">
      <%= render "contracts/governance" %>
    </div>

    <input id="contract_tab_source" data-turbo-permanent type="radio" name="contract_view" role="tab" class="tab" aria-label="Source" />
    <div role="tabpanel" class="tab-content bg-base-100 border-base-300 p-6">
      <%= render "contracts/source" %>
    </div>
  </div>
</div>

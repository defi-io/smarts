<% if @admin_risk %>
<section class="mb-6 card bg-base-200 border border-base-300">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <p class="text-xs uppercase tracking-wide opacity-60 mb-1">Admin & Risk</p>
        <h2 class="card-title text-2xl">Who can change the rules?</h2>
      </div>
      <% if @admin_risk.block_number %>
        <span class="text-xs opacity-60 font-mono">Block #<%= number_with_delimiter(@admin_risk.block_number) %></span>
      <% end %>
    </div>

    <p class="text-sm opacity-80"><%= @admin_risk.summary %></p>

    <% if @protocol_adapter.is_a?(ProtocolAdapters::PolymarketAdapter) %>
      <div class="alert alert-info alert-soft mt-4 text-sm">
        <div>
          <div class="font-semibold">Polymarket contract governance</div>
          <div class="opacity-80">
            Ask your AI who can pause, upgrade, or change roles on this Polymarket contract.
          </div>
        </div>
      </div>
    <% end %>

    <% if @admin_risk.error.present? %>
      <div class="alert alert-warning alert-soft mt-3">
        <span>Could not refresh admin/risk profile: <%= @admin_risk.error %></span>
      </div>
    <% end %>

    <% if @admin_risk.risk_flags.any? %>
      <div class="flex gap-2 flex-wrap mt-3">
        <% @admin_risk.risk_flags.each do |flag| %>
          <span class="badge <%= admin_risk_badge_class(flag) %>"><%= admin_risk_flag_label(flag) %></span>
        <% end %>
      </div>
    <% end %>

    <% if @admin_risk.controls.any? %>
      <div class="mt-5">
        <h3 class="font-semibold mb-2">Current controls</h3>
        <dl class="grid grid-cols-1 md:grid-cols-[11rem_1fr] gap-x-4 gap-y-2 text-sm">
          <% @admin_risk.controls.each do |control| %>
            <dt class="opacity-60"><%= control[:label] %></dt>
            <dd class="font-mono break-all flex flex-wrap items-center gap-x-3 gap-y-1">
              <% if control[:type] == "address" %>
                <% addr = admin_risk_value(control) %>
                <% is_zero = addr == "0x0000000000000000000000000000000000000000" %>
                <span><%= addr %></span>
                <% ens = (!is_zero && @chain.slug == "eth") ? ChainReader::EnsResolver.call(chain: @chain, address: addr) : nil %>
                <% if ens %>
                  <span class="badge badge-outline badge-xs"><%= ens %></span>
                <% end %>
                <% if is_zero %>
                  <span class="text-xs opacity-60">(none)</span>
                <% else %>
                  <% if (etherscan = explorer_address_url(@chain, addr)) %>
                    <a href="<%= etherscan %>" target="_blank" rel="noopener"
                       class="text-xs opacity-70 hover:opacity-100 hover:text-primary">
                      ↗ <%= explorer_name(@chain) %>
                    </a>
                  <% end %>
                  <%= link_to "→ smarts", contract_path(chain: @chain.slug, address: addr),
                        class: "text-xs opacity-70 hover:opacity-100 hover:text-primary",
                        title: "View on smarts.md (if verified)" %>
                <% end %>
              <% else %>
                <%= admin_risk_value(control) %>
              <% end %>
              <% if control[:source] == "proxy" %>
                <span class="badge badge-xs badge-ghost">proxy</span>
              <% end %>
            </dd>
          <% end %>
        </dl>
      </div>
    <% end %>

    <% if @admin_risk.recent_governance[:count].to_i.positive? %>
      <div class="mt-5 text-sm">
        <h3 class="font-semibold mb-1">Recent governance</h3>
        <p class="opacity-70">
          <%= pluralize(@admin_risk.recent_governance[:count], "privileged event") %> loaded.
          <% if @admin_risk.recent_governance[:latest_event] %>
            Latest: <span class="font-mono"><%= @admin_risk.recent_governance[:latest_event] %></span>
            <% if @admin_risk.recent_governance[:latest_block] %>
              at block #<%= number_with_delimiter(@admin_risk.recent_governance[:latest_block]) %>.
            <% end %>
          <% end %>
        </p>
      </div>
    <% end %>

    <% if @admin_risk.warnings.any? %>
      <ul class="mt-4 text-xs opacity-60 list-disc list-inside">
        <% @admin_risk.warnings.each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    <% end %>
  </div>
</section>
<% end %>
